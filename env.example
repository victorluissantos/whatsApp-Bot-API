# Configurações do MongoDB
MONGO_USER=admin
MONGO_PASSWORD=password
MONGO_DB=whatsapp_bot
# Em docker-compose, use o nome do serviço como host (ex.: mongo), ou deixe o compose definir MONGO_URI.
MONGO_NAME=mongo
MONGO_PORT=27017
MONGO_COLLECTION=mensagens
# Opcional: se definido, tem prioridade sobre MONGO_USER/MONGO_NAME/... (o compose injeta com host mongo).
# MONGO_URI=mongodb://admin:password@mongo:27017/whatsapp_bot?authSource=admin

# Configurações do FastAPI
FASTAPI_PORT=8000:8000
FASTAPI_NAME=fastapi-app
