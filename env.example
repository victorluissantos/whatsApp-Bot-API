# Copie para .env e ajuste os valores:
#   cp .env-example .env
#   (ou: cp env.example .env)
#
# O arquivo .env não vai para o Git (.gitignore).

# --- Fuso horário (IANA) ---
# Usado pelo sistema, Python, Chrome/WhatsApp Web e faixas de horário dos triggers.
# Brasil: America/Sao_Paulo  |  Lista: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Após alterar, reinicie: docker compose down && docker compose up -d --build
# Confira: GET http://localhost:8000/system/timezone
TZ=America/Sao_Paulo

# --- MongoDB (docker-compose) ---
MONGOUSER=admin
MONGOPASSWORD=change-me
MONGODB=whatsapp_bot
MONGONAME=mongo-container
MONGOPORT=27017
MONGOCOLLECTION=mensagens

# Opcional: URI completa (tem prioridade no código se definida).
# O compose já injeta MONGO_URI com host `mongo` na rede interna.
# MONGO_URI=mongodb://admin:change-me@mongo:27017/whatsapp_bot?authSource=admin

# --- FastAPI / container principal ---
FASTAPIPORT=8000:8000
FASTAPINAME=fastapi-app

# --- RabbitMQ (fila assíncrona de envio) ---
RABBITMQ_USER=adminMQ
RABBITMQ_PASS=change-me
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_SEND_QUEUE=wa_send_message_async
RABBITMQNAME=rabbitmq

# --- Watcher de não lidas (#pane-side) / triggers ---
# Intervalo em segundos para ler a lista de não lidas
UNREAD_PANE_POLL_SECONDS=5
# Máximo de chats lidos por ciclo (1–200)
UNREAD_PANE_MAX_CHATS=100

# --- Envio de mensagens ---
# Espera (em segundos) após pressionar Enter e antes de sair do chat (ESC).
# Aumente em rede lenta para evitar mensagem presa com "reloginho".
WA_POST_SEND_WAIT_SECONDS=2.5
