# Fuso horário do container (IANA, ex.: America/Sao_Paulo). Usado pelo sistema, Python e Chrome/WhatsApp Web.
# Lista: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones — após mudar, reinicie o compose.
TZ=America/Sao_Paulo

# Configurações do MongoDB
MONGO_USER=admin
MONGO_PASSWORD=password
MONGO_DB=whatsapp_bot
# Em docker-compose, use o nome do serviço como host (ex.: mongo), ou deixe o compose definir MONGO_URI.
MONGO_NAME=mongo
MONGO_PORT=27017
MONGO_COLLECTION=mensagens
# Opcional: se definido, tem prioridade sobre MONGO_USER/MONGO_NAME/... (o compose injeta com host mongo).
# MONGO_URI=mongodb://admin:password@mongo:27017/whatsapp_bot?authSource=admin

# Configurações do FastAPI
FASTAPI_PORT=8000:8000
FASTAPI_NAME=fastapi-app

# Lista não lidas: intervalo (s) para comparar #pane-side e atualizar cache / webhook
UNREAD_PANE_POLL_SECONDS=5
# Máximo de linhas lidas do painel por ciclo (1–200)
UNREAD_PANE_MAX_CHATS=100
